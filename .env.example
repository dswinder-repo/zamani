# ─── Zamani Data Provider Configuration ────────────────────────────────────────
# Copy this file to .env.local and fill in your API keys.
# Never commit .env.local — it is gitignored.

# Which provider to use: "mock" | "twelve" | "eodhd"
VITE_DATA_PROVIDER=mock

# ─── Twelve Data ─────────────────────────────────────────────────────────────
# https://twelvedata.com — free tier: 800 req/day, 8 req/min
# Covers: global equities, forex, ETFs, crypto
VITE_TWELVE_DATA_KEY=

# ─── EODHD (End of Day Historical Data) ──────────────────────────────────────
# https://eodhd.com — good African market coverage (JSE, NGX, NSE, etc.)
# Free tier: 20 API calls/day (limited). Paid plans from $19.99/mo.
VITE_EODHD_KEY=

# ─── Optional: Alpha Vantage (commodities fallback) ───────────────────────────
# https://www.alphavantage.co — free tier: 25 req/day
VITE_ALPHA_VANTAGE_KEY=
